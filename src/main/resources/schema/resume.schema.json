{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/sthwalo/resumes/schema/v1/resume.schema.json",
  "title": "Resume",
  "description": "ATS-compliant resume data schema v1",
  "type": "object",
  "required": ["format", "data"],
  "properties": {
    "format": {
      "type": "string",
      "enum": ["html", "pdf", "docx"],
      "description": "Output format"
    },
    "data": {
      "type": "object",
      "required": ["personalInfo"],
      "properties": {
        "personalInfo": {
          "type": "object",
          "required": ["fullName", "email", "phone"],
          "properties": {
            "fullName": { "type": "string" },
            "email":    { "type": "string", "format": "email" },
            "phone":    { "type": "string" },
            "location": { "type": "string", "description": "City, State — no street address" },
            "linkedIn": { "type": "string", "description": "linkedin.com/in/<value>" },
            "github":   { "type": "string" },
            "website":  { "type": "string" }
          }
        },
        "summary": {
          "type": "string",
          "description": "2-4 sentence professional summary (30-100 words)"
        },
        "experience": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["jobTitle", "company", "startDate"],
            "properties": {
              "jobTitle":  { "type": "string" },
              "company":   { "type": "string" },
              "location":  { "type": "string" },
              "startDate": { "type": "string", "pattern": "^(0[1-9]|1[0-2])/\\d{4}$", "description": "MM/YYYY" },
              "endDate":   { "type": "string", "pattern": "^(0[1-9]|1[0-2])/\\d{4}$", "description": "MM/YYYY" },
              "current":   { "type": "boolean", "default": false },
              "bullets":   { "type": "array", "items": { "type": "string" }, "description": "Achievement bullets starting with action verbs" }
            }
          }
        },
        "education": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["degree", "institution"],
            "properties": {
              "degree":         { "type": "string" },
              "institution":    { "type": "string" },
              "location":       { "type": "string" },
              "graduationDate": { "type": "string", "pattern": "^(0[1-9]|1[0-2])/\\d{4}$" },
              "gpa":            { "type": "string" },
              "honors":         { "type": "string" }
            }
          }
        },
        "skills": {
          "type": "object",
          "properties": {
            "technical": { "type": "array", "items": { "type": "string" } },
            "tools":     { "type": "array", "items": { "type": "string" } },
            "soft":      { "type": "array", "items": { "type": "string" } },
            "languages": { "type": "array", "items": { "type": "string" } }
          }
        },
        "certifications": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name":       { "type": "string" },
              "issuer":     { "type": "string" },
              "date":       { "type": "string", "pattern": "^(0[1-9]|1[0-2])/\\d{4}$" },
              "expiryDate": { "type": "string", "pattern": "^(0[1-9]|1[0-2])/\\d{4}$" }
            }
          }
        },
        "projects": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name":         { "type": "string" },
              "description":  { "type": "string" },
              "technologies": { "type": "array", "items": { "type": "string" } },
              "url":          { "type": "string" },
              "bullets":      { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
